<Window x:Class="MCServerManager.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="サーバー追加" Height="300" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#2C2C2C" Foreground="#EEEEEE">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="Foreground" Value="#EEEEEE" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Background" Value="#4C8A3C" /> <!-- 草ブロックっぽくね -->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#366629" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- サーバー名 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="サーバー名:" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" />

        <!-- フォルダパス -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="フォルダ:" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
        <Button Grid.Row="2" Grid.Column="2" Content="参照" Command="{Binding BrowseFolderCommand}" />

        <!-- batファイルパス -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="起動ファイル:" />
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BatFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
        <Button Grid.Row="4" Grid.Column="2" Content="参照" Command="{Binding BrowseBatCommand}" />

        <!-- アクションボタン -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Command="{Binding CancelCommand}" Background="#777777" BorderBrush="#555555" />
            <Button Content="追加" Command="{Binding SaveCommand}" MinWidth="100" Margin="10,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
