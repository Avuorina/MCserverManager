<Window x:Class="MCServerManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:MCServerManager.ViewModels"
        Title="Minecraft Server Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" Foreground="#EEEEEE">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button" x:Key="GrassButtonStyle">
            <Setter Property="Background" Value="#4C8A3C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="15,5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderBrush" Value="#366629" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="Button" x:Key="DeleteButtonStyle">
            <Setter Property="Background" Value="#C94A4A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="15,5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderBrush" Value="#8F3030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="RowBackground" Value="#333333" />
            <Setter Property="AlternatingRowBackground" Value="#3D3D3D" />
            <Setter Property="Foreground" Value="#EEEEEE" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#404040" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="10,5" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="BorderBrush" Value="#555555" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#333333" Padding="10">
            <Button Content="➕ サーバー追加" Command="{Binding AddServerCommand}" Style="{StaticResource GrassButtonStyle}"/>
            <Button Content="🔄 一覧更新" Command="{Binding RefreshCommand}" Style="{StaticResource GrassButtonStyle}"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
            <Button Content="🗑 選択削除" Command="{Binding DeleteServerCommand}" Style="{StaticResource DeleteButtonStyle}"/>
        </StackPanel>

        <!-- サーバーリスト -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#555555"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="サーバー名" Binding="{Binding Name}" Width="150" />
                <DataGridTextColumn Header="ポート" Binding="{Binding Port}" Width="80" />
                <DataGridTextColumn Header="ステータス" Binding="{Binding Status}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Foreground" Value="#4CAF50" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                    <Setter Property="Foreground" Value="#9E9E9E" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="パス" Binding="{Binding FolderPath}" Width="200" />
                
                <DataGridTemplateColumn Header="アクション" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="起動するわ！(魔法)" Command="{Binding DataContext.StartServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource GrassButtonStyle}" Padding="10,2" Margin="2" />
                                <Button Content="フォルダを開く" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}"
                                        Background="#555555" Foreground="White" BorderBrush="#333333" Padding="10,2" Margin="2" Cursor="Hand" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
